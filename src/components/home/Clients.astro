---
import { Icon } from '@twodft/astro-icon/components';
import { clients } from "../../content/Clients/clients";

const track = [ ...clients, ...clients];
---

{clients.length > 0 && (
    <section class="pt-24">
        <div class="text-center mb-12">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary-container text-on-secondary-container text-sm font-medium mb-6">
                <Icon name="material-symbols:handshake-outline" class="w-4 h-4" />
                <span>Empresas que confían en nosotros</span>
            </div>

            <h2 class="text-3xl font-semibold tracking-tight">
                Clientes y aliados
            </h2>
        </div>

        <div class="relative overflow-hidden mask-[linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
            <div class="clients-track flex items-center gap-8 w-max">
                {track.map((client, i) => (
                    client.url ? (
                        <a 
                            href={client.url}
                            target="_blank"    
                            rel="noopener noreferrer"
                            class="shrink-0 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition duration-300"
                            aria-label={`Visitar ${client.name}`}
                            tabindex={i < clients.length ? 0 : -1}
                        >
                            <img 
                                src={client.logo}
                                alt={client.name}
                                class="h-14 w-auto object-contain"
                                loading="lazy"
                            />
                        </a>
                    ) : (
                        <div class="shrink-0 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition duration-300" title={client.name}>
                            <img 
                                src={client.logo}
                                alt={client.name}
                                class="h-14 w-auto object-contain"
                                loading="lazy"
                            />
                        </div>
                    )
                ))}
            </div>
        </div>
    </section>
)}

<style>
    .clients-track {
        animation: clients-scroll 35s linear infinite;
    }
 
    .relative:hover .clients-track {
        animation-play-state: paused;
    }
 
    @keyframes clients-scroll {
        from {
            transform: translateX(0);
        }
        to {
            /* -50% porque la pista esta duplicada (2x el contenido real) */
            transform: translateX(-50%);
        }
    }
 
    @media (prefers-reduced-motion: reduce) {
        .clients-track {
            animation: none;
        }
    }
</style>
