---
import '../styles/global.css' 
import Header from "../components/layouts/Header.astro"
import Footer from "../components/layouts/Footer.astro"
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/ConstrutoraSantana/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Constructora Santana Díaz SRL — Diseño, presupuestos y construcción de servicios de ingeniería civil en Punta Cana y toda la República Dominicana desde 2007." />
		<title>Construtora Santana</title>
 
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
			rel="stylesheet"
		/>

		<ClientRouter />
	</head>
	<body class="bg-background text-on-surface antialiased font-sans">
	    <Header />
		
		<main class="max-w-7xl mx-auto px-4 pt-24">
			<slot />
		</main>
		
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
